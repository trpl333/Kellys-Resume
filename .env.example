# Contact form backend (Resend + Twilio). Copy to `.env` for local dev.
# Never commit `.env` with real secrets.

# Resend — https://resend.com (domain kellypetersonsped.com verified)
RESEND_API_KEY=
# Verified sending address on your domain, e.g. admin@kellypetersonsped.com
RESEND_FROM_EMAIL=admin@kellypetersonsped.com
# Where inquiry emails are delivered
CONTACT_TO_EMAIL=kellykaypeterson@gmail.com

# Twilio — https://www.twilio.com (trial accounts can only SMS verified numbers)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164, e.g. +12065551234 (your Twilio number)
TWILIO_FROM_NUMBER=
# E.164 — Kelly’s mobile for SMS alerts
TWILIO_TO_NUMBER=

# Optional: dev API port (default 8788)
# CONTACT_API_PORT=8788
